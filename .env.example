# ─── TanaCebu Bot — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control!

# Facebook Page Access Token (from Meta Developer App → Messenger → Token)
PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# Your custom verification token (any string you choose, set it in Meta webhook settings)
VERIFY_TOKEN=your_custom_verify_token_here

# Google Gemini API Key (from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: port to run Flask on (default: 5000)
PORT=5000
